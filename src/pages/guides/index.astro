---
import Base from '../../layouts/Base.astro';
import ReadingList from '../../components/ReadingList.astro';
import { getEntry, render } from 'astro:content';

const guides = await getEntry('pages', 'guides');
if (!guides) throw new Error('Missing pages/guides entry');
const { description, reading } = guides.data;
const { Content } = await render(guides);
---

<Base title={`Guides — harnessed.md`} description={description} class="narrow">
	<section class="guides">
		<Content />
	</section>

	{reading && (
		<hr />
		<ReadingList title="Further reading" items={reading} />
	)}
</Base>

<style is:global>
	.guides {
		margin-bottom: 2rem;
	}

	.guides ul {
		margin: 0 0 1rem 1.5rem;
	}

	.guides li {
		margin-bottom: 0.25rem;
	}

	.guides code {
		font-size: 0.85rem;
		background: var(--code-bg);
		padding: 0.1rem 0.3rem;
		border-radius: 3px;
	}

	.guides pre code {
		background: none;
		padding: 0;
	}

	.guides table {
		min-width: 100%;
		border-collapse: collapse;
		font-size: 0.85rem;
		margin-bottom: 1rem;
	}

	.guides th {
		text-align: left;
		font-weight: 700;
		padding: 0.5rem 0.75rem;
		border-bottom: 1px solid var(--border);
	}

	.guides td {
		padding: 0.5rem 0.75rem;
		border-bottom: 1px solid var(--border);
	}

	.guides tr:last-child td {
		border-bottom: none;
	}
</style>
