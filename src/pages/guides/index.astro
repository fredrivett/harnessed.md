---
import Base from '../../layouts/Base.astro';
import ReadingList from '../../components/ReadingList.astro';
import { getEntry, render } from 'astro:content';
import { lastModified } from '../../lib/gitdate';

const guides = await getEntry('pages', 'guides');
if (!guides) throw new Error('Missing pages/guides entry');
const { description, reading } = guides.data;
const { Content } = await render(guides);
const updated = lastModified('src/data/guides.md');
---

<Base title={`Guides — harnessed.md`} description={description} class="narrow" updated={updated}>
	<section class="prose">
		<Content />
	</section>

	<script>
		document.querySelectorAll('.prose table').forEach((table) => {
			const wrap = document.createElement('div');
			wrap.className = 'table-wrap';
			table.parentNode!.insertBefore(wrap, table);
			wrap.appendChild(table);
		});
	</script>

	{reading && (
		<hr />
		<ReadingList title="Further reading" items={reading} />
	)}
</Base>
