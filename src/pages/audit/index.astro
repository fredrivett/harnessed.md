---
import Base from '../../layouts/Base.astro';
import { getEntry, render } from 'astro:content';

const audit = await getEntry('pages', 'audit');
if (!audit) throw new Error('Missing pages/audit entry');
const { description } = audit.data;
const { Content } = await render(audit);
---

<Base title={`Audit — harnessed.md`} description={description} class="narrow">
	<section class="prose">
		<Content />
	</section>

	<script>
		document.querySelectorAll('.prose table').forEach((table) => {
			const wrap = document.createElement('div');
			wrap.className = 'table-wrap';
			table.parentNode!.insertBefore(wrap, table);
			wrap.appendChild(table);
		});
	</script>
</Base>
