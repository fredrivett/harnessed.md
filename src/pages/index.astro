---
import Base from '../layouts/Base.astro';
import { getEntry, render } from 'astro:content';

const home = await getEntry('pages', 'home');
const { quote, reading, description } = home.data;
const { Content } = await render(home);
---

<Base title="harnessed.md" description={description}>
	<blockquote class="hero-quote">
		<p>"{quote.text}"</p>
		<cite>— <a href={quote.url} target="_blank" rel="noopener">{quote.source}</a></cite>
	</blockquote>

	<hr />

	<section class="what">
		<Content />
	</section>

	<hr />

	<section class="reading">
		<h2 id="reading"><a class="heading-hash" href="#reading">##</a>Key reading</h2>
		<ul>
			{reading.map((item) => (
				<li><a href={item.url} target="_blank" rel="noopener">{item.title}</a> — {item.author} <span class="tag">{item.tag}</span></li>
			))}
		</ul>
	</section>
</Base>
