---
import Base from '../layouts/Base.astro';
import ReadingList from '../components/ReadingList.astro';
import { getEntry, getCollection, render } from 'astro:content';
import { fetchJobs, salaryRange, getExchangeRates, type Job } from '../lib/jobs';

const home = await getEntry('pages', 'home');
if (!home) throw new Error('Missing pages/home entry');
const { quote, reading, description } = home.data;
if (!quote || !reading) throw new Error('Home page must have quote and reading');
const { Content } = await render(home);

const companies = await getCollection('companies');

const jobResults = await Promise.all(
	companies.map((c) => fetchJobs(c.data.name, c.data.ats))
);
const jobsByCompany = new Map<string, Job[]>();
companies.forEach((c, i) => jobsByCompany.set(c.data.name, jobResults[i]!));
const allJobs = jobResults.flat();
const anySalary = allJobs.some((j) => j.salary);
const rates = anySalary ? await getExchangeRates() : null;
---

<Base title={`harnessed.md — ${description}`} description={description} class="narrow">
	<blockquote class="hero-quote">
		<p>"{quote.text}"</p>
		<cite>— <a href={quote.url} target="_blank" rel="noopener">{quote.source}</a></cite>
	</blockquote>

	<hr />

	<section class="what">
		<Content />
	</section>

	<hr />

	<ReadingList title="Key reading" items={reading} />

	<hr />

	<section class="companies">
		<h2 id="companies"><a class="heading-hash" href="#companies">##</a>Companies</h2>
		<p>Software engineering has radically changed. These companies have seen it early and gone all-in on harness engineering. They're hiring.</p>
		{anySalary && (
			<select id="currency-setting" class="currency-setting">
				<option value="USD">$ USD</option>
				<option value="EUR">€ EUR</option>
				<option value="GBP">£ GBP</option>
			</select>
		)}
		<div class="table-wrap">
			<table>
				<thead>
					<tr>
						<th>Name</th>
						<th>Openings</th>
						{anySalary && <th>Salary</th>}
						<th>Stage</th>
						<th>Headcount</th>
					</tr>
				</thead>
				<tbody>
					{companies.map((company) => {
						const jobs = jobsByCompany.get(company.data.name) || [];
						const jobCount = jobs.length;
						const range = salaryRange(jobs);
						return (
						<tr>
							<td><a href={`/companies/${company.id.replace(/^\d+-/, '')}`}>{company.data.name}</a></td>
							<td>{jobCount
								? <a href={`/companies/${company.id.replace(/^\d+-/, '')}#jobs`}>{jobCount}</a>
								: '—'}</td>
							{anySalary && <td style="white-space:nowrap" data-salary-usd={range || ''}>{range || '—'}</td>}
							<td style="white-space:nowrap">{company.data.stage}</td>
							<td>{company.data.headcount}</td>
						</tr>
						);
					})}
				</tbody>
			</table>
		</div>
		<p class="all-jobs-link"><a href="/jobs">Browse all openings →</a></p>
	</section>

	<hr />

	<section class="newsletter">
		<h2 id="subscribe"><a class="heading-hash" href="#subscribe">##</a>Stay in the loop</h2>
		<p>Get updates on harness engineering — new articles, companies, and tools.</p>
		<form
			action="https://buttondown.com/api/emails/embed-subscribe/harnessed-md"
			method="post"
			target="bd-iframe"
		>
			<input type="email" name="email" placeholder="you@example.com" required />
			<button type="submit">Subscribe</button>
		</form>
		<p class="newsletter-thanks" hidden>Thanks! Check your inbox to confirm.</p>
		<iframe name="bd-iframe" hidden></iframe>
	</section>

	{rates && <script is:inline define:vars={{ rates }}>
		window.__exchangeRates = rates;
	</script>}
	<script>
		// Currency conversion
		const currencySelect = document.getElementById('currency-setting') as HTMLSelectElement | null;
		const symbols: Record<string, string> = { USD: '$', EUR: '€', GBP: '£' };

		const saved = localStorage.getItem('currency');
		if (saved && currencySelect) {
			currencySelect.value = saved;
		}

		function convertCurrency() {
			const currency = currencySelect?.value || 'USD';
			localStorage.setItem('currency', currency);
			const rates = (window as any).__exchangeRates as Record<string, number> | undefined;
			if (!rates) return;
			const rate = rates[currency] ?? 1;
			const symbol = symbols[currency] ?? '$';

			document.querySelectorAll('td[data-salary-usd]').forEach((td) => {
				const usd = (td as HTMLElement).dataset.salaryUsd || '';
				if (!usd) { td.textContent = '—'; return; }
				const converted = usd.replace(/\$(\d+)K/g, (_, n: string) => {
					const val = Math.round(Number(n) * rate);
					return `${symbol}${val}K`;
				});
				td.textContent = converted;
			});
		}

		currencySelect?.addEventListener('change', convertCurrency);
		if (saved && saved !== 'USD') convertCurrency();

		const form = document.querySelector('.newsletter form') as HTMLFormElement | null;
		form?.addEventListener('submit', () => {
			setTimeout(() => {
				form.hidden = true;
				document.querySelector('.newsletter-thanks')?.removeAttribute('hidden');
			}, 500);
		});
	</script>
</Base>

<style is:global>
	.currency-setting {
		padding: 0.4rem 0.6rem;
		font-family: inherit;
		font-size: 0.85rem;
		color: var(--text);
		background: var(--bg);
		border: 1px solid var(--border);
		border-radius: 4px;
		margin-bottom: 0.5rem;
	}
</style>
