---
import Base from '../layouts/Base.astro';
import { getEntry, render } from 'astro:content';

const home = await getEntry('pages', 'home');
const { quote, reading, description } = home.data;
const { Content } = await render(home);
---

<Base title="harnessed.md" description={description}>
	<blockquote class="hero-quote">
		<p>"{quote.text}"</p>
		<cite>— <a href={quote.url} target="_blank" rel="noopener">{quote.source}</a></cite>
	</blockquote>

	<hr />

	<section class="what">
		<Content />
	</section>

	<hr />

	<section class="reading">
		<h2 id="reading"><a class="heading-hash" href="#reading">##</a>Key reading</h2>
		<ul>
			{reading.map((item) => (
				<li><a href={item.url} target="_blank" rel="noopener">{item.title}</a> — {item.author} <span class="tag">{item.tag}</span></li>
			))}
		</ul>
	</section>
</Base>

<style>
	.hero-quote {
		border-left: 2px solid var(--border);
		padding-left: 1rem;
		margin-bottom: 2rem;
	}

	.hero-quote p {
		font-style: italic;
	}

	.hero-quote cite {
		font-size: 0.85rem;
		color: var(--text-secondary);
		font-style: normal;
	}

	.hero-quote cite a {
		color: var(--text-secondary);
	}

	.what {
		margin-bottom: 2rem;
	}

	.what p {
		margin-bottom: 1rem;
	}

	.what p:last-child {
		margin-bottom: 0;
	}

	.what ul {
		margin: 0 0 1rem 1.5rem;
	}

	.what li {
		margin-bottom: 0.25rem;
	}

	.reading {
		margin-bottom: 2rem;
	}

	.reading ul {
		list-style: none;
		margin: 0;
	}

	.reading li {
		margin-bottom: 0.75rem;
	}

	.tag {
		font-size: 0.75rem;
		color: var(--text-secondary);
	}
</style>
