---
import Base from '../layouts/Base.astro';
import { getEntry, getCollection, render } from 'astro:content';

const home = await getEntry('pages', 'home');
const { quote, reading, description } = home.data;
const { Content } = await render(home);

const companies = await getCollection('companies');
---

<Base title={`harnessed.md — ${description}`} description={description}>
	<blockquote class="hero-quote">
		<p>"{quote.text}"</p>
		<cite>— <a href={quote.url} target="_blank" rel="noopener">{quote.source}</a></cite>
	</blockquote>

	<hr />

	<section class="what">
		<Content />
	</section>

	<hr />

	<section class="reading">
		<h2 id="reading"><a class="heading-hash" href="#reading">##</a>Key reading</h2>
		<ul>
			{reading.map((item) => (
				<li><a href={item.url} target="_blank" rel="noopener">{item.title}</a> — {item.author} <span class="tag">{item.tag}</span></li>
			))}
		</ul>
	</section>

	<hr />

	<section class="companies">
		<h2 id="companies"><a class="heading-hash" href="#companies">##</a>Companies</h2>
		<ul>
			{companies.map((company) => (
				<li>
					<a href={company.data.url} target="_blank" rel="noopener">{company.data.name}</a> — {company.data.description}
					<span class="tag"><a href={company.data.reference.url} target="_blank" rel="noopener">{company.data.reference.title}</a></span>
				</li>
			))}
		</ul>
	</section>

	<hr />

	<section class="newsletter">
		<h2 id="subscribe"><a class="heading-hash" href="#subscribe">##</a>Stay in the loop</h2>
		<p>Get updates on harness engineering — new articles, companies, and tools.</p>
		<form
			action="https://buttondown.com/api/emails/embed-subscribe/harnessed-md"
			method="post"
			target="bd-iframe"
		>
			<input type="email" name="email" placeholder="you@example.com" required />
			<button type="submit">Subscribe</button>
		</form>
		<p class="newsletter-thanks" hidden>Thanks! Check your inbox to confirm.</p>
		<iframe name="bd-iframe" hidden></iframe>
	</section>

	<script>
		const form = document.querySelector('.newsletter form');
		form?.addEventListener('submit', () => {
			setTimeout(() => {
				form.hidden = true;
				document.querySelector('.newsletter-thanks')?.removeAttribute('hidden');
			}, 500);
		});
	</script>
</Base>
