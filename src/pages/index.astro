---
import Base from '../layouts/Base.astro';
import { getEntry, getCollection, render } from 'astro:content';
import { fetchJobs, type Job } from '../lib/jobs';

const home = await getEntry('pages', 'home');
const { quote, reading, description } = home.data;
const { Content } = await render(home);

const companies = await getCollection('companies');

const jobResults = await Promise.all(
	companies.map((c) => fetchJobs(c.data.name, c.data.ats))
);
const jobsByCompany = new Map<string, Job[]>();
companies.forEach((c, i) => jobsByCompany.set(c.data.name, jobResults[i]));
---

<Base title={`harnessed.md — ${description}`} description={description}>
	<blockquote class="hero-quote">
		<p>"{quote.text}"</p>
		<cite>— <a href={quote.url} target="_blank" rel="noopener">{quote.source}</a></cite>
	</blockquote>

	<hr />

	<section class="what">
		<Content />
	</section>

	<hr />

	<section class="reading">
		<h2 id="reading"><a class="heading-hash" href="#reading">##</a>Key reading</h2>
		<ul>
			{reading.map((item) => (
				<li><a href={item.url} target="_blank" rel="noopener">{item.title}</a> — {item.author} <span class="tag">{item.tag}</span></li>
			))}
		</ul>
	</section>

	<hr />

	<section class="companies">
		<h2 id="companies"><a class="heading-hash" href="#companies">##</a>Companies</h2>
		<p>Who's doing this? Companies that have gone all-in on harness engineering.</p>
		<div class="table-wrap">
			<table>
				<thead>
					<tr>
						<th data-sort="string">Name</th>
						<th data-sort="string">Source</th>
						<th data-sort="string">Stage</th>
						<th data-sort="number">Headcount</th>
						<th data-sort="number">Jobs</th>
					</tr>
				</thead>
				<tbody>
					{companies.map((company) => {
						const jobCount = (jobsByCompany.get(company.data.name) || []).length;
						const headcountNum = parseInt(company.data.headcount.replace(/[^0-9]/g, ''));
						return (
						<tr>
							<td data-value={company.data.name}><a href={`/companies/${company.id.replace(/^\d+-/, '')}`}>{company.data.name}</a></td>
							<td data-value={company.data.reference.title}><a href={company.data.reference.url} target="_blank" rel="noopener">{company.data.reference.title}</a></td>
							<td data-value={company.data.stage}>{company.data.stage}</td>
							<td data-value={headcountNum}>{company.data.headcount}</td>
							<td data-value={jobCount}>{jobCount
								? <a href={`/companies/${company.id.replace(/^\d+-/, '')}#jobs`}>{jobCount}</a>
								: '—'}</td>
						</tr>
						);
					})}
				</tbody>
			</table>
		</div>
	</section>

	<hr />

	<section class="newsletter">
		<h2 id="subscribe"><a class="heading-hash" href="#subscribe">##</a>Stay in the loop</h2>
		<p>Get updates on harness engineering — new articles, companies, and tools.</p>
		<form
			action="https://buttondown.com/api/emails/embed-subscribe/harnessed-md"
			method="post"
			target="bd-iframe"
		>
			<input type="email" name="email" placeholder="you@example.com" required />
			<button type="submit">Subscribe</button>
		</form>
		<p class="newsletter-thanks" hidden>Thanks! Check your inbox to confirm.</p>
		<iframe name="bd-iframe" hidden></iframe>
	</section>

	<script>
		document.querySelectorAll('th[data-sort]').forEach((th) => {
			th.style.cursor = 'pointer';
			th.addEventListener('click', () => {
				const table = th.closest('table')!;
				const tbody = table.querySelector('tbody')!;
				const idx = Array.from(th.parentElement!.children).indexOf(th);
				const type = th.getAttribute('data-sort');
				const rows = Array.from(tbody.querySelectorAll('tr'));

				const currentDir = th.getAttribute('aria-sort');
				const asc = currentDir !== 'ascending';

				table.querySelectorAll('th[data-sort]').forEach((h) => h.removeAttribute('aria-sort'));
				th.setAttribute('aria-sort', asc ? 'ascending' : 'descending');

				rows.sort((a, b) => {
					const aVal = a.children[idx].getAttribute('data-value') || '';
					const bVal = b.children[idx].getAttribute('data-value') || '';
					if (type === 'number') {
						return asc ? Number(aVal) - Number(bVal) : Number(bVal) - Number(aVal);
					}
					return asc ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
				});

				rows.forEach((row) => tbody.appendChild(row));
			});
		});

		const form = document.querySelector('.newsletter form');
		form?.addEventListener('submit', () => {
			setTimeout(() => {
				form.hidden = true;
				document.querySelector('.newsletter-thanks')?.removeAttribute('hidden');
			}, 500);
		});
	</script>
</Base>
