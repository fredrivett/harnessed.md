---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { fetchJobs } from '../../../lib/jobs';
import { slugFromId } from '../../../lib/slug';
import { lastModified } from '../../../lib/gitdate';

export async function getStaticPaths() {
	const companies = await getCollection('companies');
	return companies.map((company) => ({
		params: { slug: slugFromId(company.id) },
		props: { company },
	}));
}

const { company } = Astro.props;
const jobs = await fetchJobs(company.data.name, company.data.ats);
const hasSalary = jobs.some((j) => j.salary);
const departments = [...new Set(jobs.map((j) => j.department).filter(Boolean))].sort();
const locations = [...new Set(jobs.map((j) => j.location).filter(Boolean))].sort();
const sources = company.data.sources || [];
const updated = lastModified(`src/data/companies/${company.id}.yaml`);
---

<Base title={`${company.data.name} — harnessed.md`} description={`${company.data.name}: ${company.data.description}`} image={`/companies/${slugFromId(company.id)}/og.png`} updated={updated}>
	<section class="company-header">
		<h2><a href={company.data.url} target="_blank" rel="noopener">{company.data.name}</a></h2>
		<p>{company.data.description}</p>
		<p class="company-meta">
			{company.data.stage} · {company.data.headcount} employees
		</p>
	</section>

	{sources.length > 0 && (
		<hr />
		<section class="sources">
			<h2 id="sources"><a class="heading-hash" href="#sources">##</a>What they've said</h2>
			<ul>
				{sources.map((source) => (
					<li><a href={source.url} target="_blank" rel="noopener">{source.title}</a></li>
				))}
			</ul>
		</section>
	)}

	<hr />

	<section class="jobs">
		<div class="jobs-header">
			<h2 id="jobs"><a class="heading-hash" href="#jobs">##</a>Engineering jobs ({jobs.length})</h2>
			{company.data.careers && <a href={company.data.careers} target="_blank" rel="noopener" class="careers-link">Careers page ↗</a>}
		</div>
		{jobs.length > 0 ? (
			<div class="jobs-filters">
				<input type="text" id="filter-role" placeholder="Search roles…" />
				{departments.length > 1 && (
					<select id="filter-department">
						<option value="">All departments</option>
						{departments.map((d) => <option value={d}>{d}</option>)}
					</select>
				)}
				{locations.length > 1 && (
					<select id="filter-location">
						<option value="">All locations</option>
						{locations.map((l) => <option value={l}>{l}</option>)}
					</select>
				)}
			</div>
			<div class="table-wrap">
				<table>
					<thead>
						<tr>
							<th data-sort="string">Role</th>
							<th data-sort="string">Department</th>
							<th data-sort="string">Location</th>
							{hasSalary && <th data-sort="string">Salary</th>}
						</tr>
					</thead>
					<tbody>
						{jobs.map((job) => (
							<tr data-role={job.title.toLowerCase()} data-department={job.department} data-location={job.location}>
								<td data-value={job.title}><a href={job.url} target="_blank" rel="noopener">{job.title}</a></td>
								<td data-value={job.department}>{job.department}</td>
								<td data-value={job.location}>{job.location}</td>
								{hasSalary && <td data-value={job.salary || ''}>{job.salary || '—'}</td>}
							</tr>
						))}
					</tbody>
				</table>
			</div>
			<p class="filter-count"></p>
		) : (
			<p>No jobs available via API. Check <a href={company.data.careers || company.data.url} target="_blank" rel="noopener">{company.data.name}'s careers page</a> directly.</p>
		)}
	</section>
	<script is:inline define:vars={{ companyName: company.data.name }}>
		document.addEventListener('DOMContentLoaded', function () {
			// Company page view (top of funnel)
			window.posthog?.capture('company_viewed', { company_name: companyName });

			// Careers page link
			const careersLink = document.querySelector('.careers-link');
			if (careersLink) {
				careersLink.addEventListener('click', function () {
					window.posthog?.capture('careers_page_clicked', { company_name: companyName });
				});
			}

			// Job link clicks
			document.querySelectorAll('.jobs tbody td:first-child a').forEach(function (link) {
				link.addEventListener('click', function () {
					const row = link.closest('tr');
					window.posthog?.capture('job_clicked', {
						job_title: link.textContent ? link.textContent.trim() : '',
						company_name: companyName,
						department: row ? (row.dataset.department || '') : '',
						location: row ? (row.dataset.location || '') : '',
						page_context: 'company_page'
					});
				});
			});

			// Source link clicks ("What they've said")
			document.querySelectorAll('.sources a').forEach(function (link) {
				link.addEventListener('click', function () {
					window.posthog?.capture('source_link_clicked', {
						company_name: companyName,
						title: link.textContent ? link.textContent.trim() : '',
						url: link.getAttribute('href') || ''
					});
				});
			});

			// Filter events
			let filterTimer;
			function captureFilter() {
				const roleInput = document.getElementById('filter-role');
				const deptSelect = document.getElementById('filter-department');
				const locSelect = document.getElementById('filter-location');
				window.posthog?.capture('jobs_filtered', {
					company_name: companyName,
					role_query: roleInput ? roleInput.value : '',
					department_filter: deptSelect ? deptSelect.value : '',
					location_filter: locSelect ? locSelect.value : '',
					page_context: 'company_page'
				});
			}
			const roleInputEl = document.getElementById('filter-role');
			if (roleInputEl) {
				roleInputEl.addEventListener('input', function () {
					clearTimeout(filterTimer);
					filterTimer = setTimeout(captureFilter, 600);
				});
			}
			['filter-department', 'filter-location'].forEach(function (id) {
				const el = document.getElementById(id);
				if (el) el.addEventListener('change', captureFilter);
			});
		});
	</script>
	<script>
		// Sorting
		document.querySelectorAll('th[data-sort]').forEach((th) => {
			th.addEventListener('click', () => {
				const table = th.closest('table')!;
				const tbody = table.querySelector('tbody')!;
				const idx = Array.from(th.parentElement!.children).indexOf(th);
				const type = th.getAttribute('data-sort');
				const rows = Array.from(tbody.querySelectorAll('tr'));

				const currentDir = th.getAttribute('aria-sort');
				const asc = currentDir !== 'ascending';

				table.querySelectorAll('th[data-sort]').forEach((h) => h.removeAttribute('aria-sort'));
				th.setAttribute('aria-sort', asc ? 'ascending' : 'descending');

				rows.sort((a, b) => {
					const aVal = a.children[idx]?.getAttribute('data-value') || '';
					const bVal = b.children[idx]?.getAttribute('data-value') || '';
					if (type === 'number') {
						return asc ? Number(aVal) - Number(bVal) : Number(bVal) - Number(aVal);
					}
					return asc ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
				});

				rows.forEach((row) => tbody.appendChild(row));
			});
		});

		// Filtering
		const roleInput = document.getElementById('filter-role') as HTMLInputElement | null;
		const deptSelect = document.getElementById('filter-department') as HTMLSelectElement | null;
		const locSelect = document.getElementById('filter-location') as HTMLSelectElement | null;
		const tbody = document.querySelector('.jobs tbody');
		const filterCount = document.querySelector('.filter-count');

		function applyFilters() {
			if (!tbody) return;
			const role = (roleInput?.value || '').toLowerCase();
			const dept = deptSelect?.value || '';
			const loc = locSelect?.value || '';
			const rows = tbody.querySelectorAll('tr');
			let visible = 0;

			rows.forEach((row) => {
				const tr = row as HTMLElement;
				const matchRole = !role || (tr.dataset.role || '').includes(role);
				const matchDept = !dept || tr.dataset.department === dept;
				const matchLoc = !loc || tr.dataset.location === loc;
				const show = matchRole && matchDept && matchLoc;
				tr.style.display = show ? '' : 'none';
				if (show) visible++;
			});

			if (filterCount) {
				const total = rows.length;
				filterCount.textContent = (role || dept || loc) ? `Showing ${visible} of ${total}` : '';
			}
		}

		roleInput?.addEventListener('input', applyFilters);
		deptSelect?.addEventListener('change', applyFilters);
		locSelect?.addEventListener('change', applyFilters);
	</script>
</Base>

<style is:global>
	.company-header {
		margin-bottom: 1rem;
	}

	.company-meta {
		font-size: 0.85rem;
		color: var(--text-secondary);
	}

	.company-meta a {
		color: var(--text-secondary);
	}

	.sources {
		margin-bottom: 1rem;
	}

	.sources ul {
		list-style: none;
		margin: 0;
	}

	.sources li {
		margin-bottom: 0.5rem;
	}

	.sources a {
		color: var(--text-secondary);
	}

	.jobs {
		margin-bottom: 2rem;
	}

	.jobs-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
	}

	.careers-link {
		font-size: 0.85rem;
		color: var(--text-secondary);
	}

	.jobs-filters {
		display: flex;
		gap: 0.5rem;
		margin-bottom: 1rem;
		flex-wrap: wrap;
	}

	.jobs-filters input,
	.jobs-filters select {
		padding: 0.4rem 0.6rem;
		font-family: inherit;
		font-size: 0.85rem;
		color: var(--text);
		background: var(--bg);
		border: 1px solid var(--border);
		border-radius: 4px;
	}

	.jobs-filters input {
		flex: 1;
		min-width: 150px;
	}

	.filter-count {
		font-size: 0.85rem;
		color: var(--text-secondary);
		margin-top: 0.5rem;
	}

	.jobs table {
		min-width: 100%;
		border-collapse: collapse;
		font-size: 0.85rem;
	}

	.jobs th {
		text-align: left;
		font-weight: 700;
		padding: 0.5rem 0.75rem;
		border-bottom: 1px solid var(--border);
	}

	.jobs th[data-sort] {
		cursor: pointer;
		user-select: none;
	}

	.jobs th[data-sort]::after {
		content: ' ↕';
		font-size: 1em;
		opacity: 0.4;
	}

	.jobs th[aria-sort="ascending"]::after {
		content: ' ↑';
		opacity: 0.8;
	}

	.jobs th[aria-sort="descending"]::after {
		content: ' ↓';
		opacity: 0.8;
	}

	.jobs td {
		padding: 0.5rem 0.75rem;
		border-bottom: 1px solid var(--border);
	}

	.jobs tr:last-child td {
		border-bottom: none;
	}
</style>
