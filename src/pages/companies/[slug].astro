---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { fetchJobs } from '../../lib/jobs';

export async function getStaticPaths() {
	const companies = await getCollection('companies');
	return companies.map((company) => ({
		params: { slug: company.id.replace(/^\d+-/, '') },
		props: { company },
	}));
}

const { company } = Astro.props;
const jobs = await fetchJobs(company.data.name, company.data.ats);
---

<Base title={`${company.data.name} — harnessed.md`} description={`${company.data.name}: ${company.data.description}`}>
	<section class="company-header">
		<h2><a href={company.data.url} target="_blank" rel="noopener">{company.data.name}</a></h2>
		<p>{company.data.description}</p>
		<p class="company-meta">
			{company.data.stage} · {company.data.headcount} employees ·
			<a href={company.data.reference.url} target="_blank" rel="noopener">{company.data.reference.title}</a>
		</p>
	</section>

	<hr />

	<section class="jobs">
		<div class="jobs-header">
			<h2 id="jobs"><a class="heading-hash" href="#jobs">##</a>Engineering jobs ({jobs.length})</h2>
			{company.data.careers && <a href={company.data.careers} target="_blank" rel="noopener" class="careers-link">Careers page ↗</a>}
		</div>
		{jobs.length > 0 ? (
			<div class="table-wrap">
				<table>
					<thead>
						<tr>
							<th data-sort="string">Role</th>
							<th data-sort="string">Department</th>
							<th data-sort="string">Location</th>
						</tr>
					</thead>
					<tbody>
						{jobs.map((job) => (
							<tr>
								<td data-value={job.title}><a href={job.url} target="_blank" rel="noopener">{job.title}</a></td>
								<td data-value={job.department}>{job.department}</td>
								<td data-value={job.location}>{job.location}</td>
							</tr>
						))}
					</tbody>
				</table>
			</div>
		) : (
			<p>No jobs available via API. Check <a href={company.data.careers || company.data.url} target="_blank" rel="noopener">{company.data.name}'s careers page</a> directly.</p>
		)}
	</section>
	<script>
		document.querySelectorAll('th[data-sort]').forEach((th) => {
			th.addEventListener('click', () => {
				const table = th.closest('table')!;
				const tbody = table.querySelector('tbody')!;
				const idx = Array.from(th.parentElement!.children).indexOf(th);
				const type = th.getAttribute('data-sort');
				const rows = Array.from(tbody.querySelectorAll('tr'));

				const currentDir = th.getAttribute('aria-sort');
				const asc = currentDir !== 'ascending';

				table.querySelectorAll('th[data-sort]').forEach((h) => h.removeAttribute('aria-sort'));
				th.setAttribute('aria-sort', asc ? 'ascending' : 'descending');

				rows.sort((a, b) => {
					const aVal = a.children[idx].getAttribute('data-value') || '';
					const bVal = b.children[idx].getAttribute('data-value') || '';
					if (type === 'number') {
						return asc ? Number(aVal) - Number(bVal) : Number(bVal) - Number(aVal);
					}
					return asc ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
				});

				rows.forEach((row) => tbody.appendChild(row));
			});
		});
	</script>
</Base>

<style is:global>
	.company-header {
		margin-bottom: 1rem;
	}

	.company-meta {
		font-size: 0.85rem;
		color: var(--text-secondary);
	}

	.company-meta a {
		color: var(--text-secondary);
	}

	.jobs {
		margin-bottom: 2rem;
	}

	.jobs-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
	}

	.careers-link {
		font-size: 0.85rem;
		color: var(--text-secondary);
	}

	.jobs table {
		min-width: 100%;
		border-collapse: collapse;
		font-size: 0.85rem;
		margin-left: -0.5rem;
		margin-right: -0.5rem;
	}

	.jobs th {
		text-align: left;
		font-weight: 700;
		padding: 0.5rem 0.75rem;
		border-bottom: 1px solid var(--border);
	}

	.jobs th[data-sort] {
		cursor: pointer;
		user-select: none;
	}

	.jobs th[data-sort]::after {
		content: ' ↕';
		font-size: 1em;
		opacity: 0.4;
	}

	.jobs th[aria-sort="ascending"]::after {
		content: ' ↑';
		opacity: 0.8;
	}

	.jobs th[aria-sort="descending"]::after {
		content: ' ↓';
		opacity: 0.8;
	}

	.jobs td {
		padding: 0.5rem 0.75rem;
		border-bottom: 1px solid var(--border);
	}

	.jobs tr:last-child td {
		border-bottom: none;
	}
</style>
