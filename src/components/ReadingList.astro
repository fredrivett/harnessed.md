---
interface Props {
	title: string;
	items: Array<{
		title: string;
		url: string;
		author: string;
		tag: string;
	}>;
}

const { title, items } = Astro.props;
const id = title.toLowerCase().replace(/\s+/g, '-');
---

<section class="reading" data-section-title={title}>
	<h2 id={id}><a class="heading-hash" href={`#${id}`}>##</a>{title}</h2>
	<ul>
		{items.map((item) => (
			<li><a href={item.url} target="_blank" rel="noopener">{item.title}</a> — {item.author} <span class="tag">{item.tag}</span></li>
		))}
	</ul>
</section>
<script is:inline>
	document.addEventListener('DOMContentLoaded', function () {
		document.querySelectorAll('.reading a[href]').forEach(function (link) {
			if (link.classList.contains('heading-hash')) return;
			link.addEventListener('click', function () {
				const section = link.closest('.reading');
				window.posthog?.capture('reading_item_clicked', {
					title: link.textContent ? link.textContent.trim() : '',
					url: link.getAttribute('href') || '',
					section_title: section ? (section.dataset.sectionTitle || '') : ''
				});
			});
		});
	});
</script>
