{
  "name": "harnessed.md",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "astro dev",
    "check": "astro check --minimumFailingSeverity warning",
    "check:links": "tsx scripts/check-links.ts",
    "check:llms-txt": "tsx scripts/check-llms-txt.ts",
    "test": "vitest run",
    "build": "astro check --minimumFailingSeverity warning && vitest run && astro build && tsx scripts/check-links.ts && tsx scripts/check-llms-txt.ts",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^6.1.3",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-slug": "^6.0.0",
    "satori": "^0.26.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.8",
    "tsx": "^4.21.0",
    "vitest": "^4.1.8"
  }
}
