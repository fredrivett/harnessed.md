{
  "name": "harnessed.md",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "astro dev",
    "check": "astro check --minimumFailingSeverity warning",
    "check:links": "tsx scripts/check-links.ts",
    "check:llms-txt": "tsx scripts/check-llms-txt.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "build:site": "astro build",
    "build": "npm run check && npm run lint && npm run test && npm run build:site && npm run check:links && npm run check:llms-txt",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^6.1.3",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-slug": "^6.0.0",
    "satori": "^0.26.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@eslint/js": "^10.0.1",
    "@posthog/rollup-plugin": "^1.4.4",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.6.0",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
